# Конфигурация shellcheck для openwrt-ipv6-off.
# Цель — busybox ash на OpenWrt. Ниже осознанно принятые исключения;
# каждое обосновано под целевую платформу, а не «замолчать линтер».

# SC2012: ls|sort вместо find — каталоги бэкапов именуются timestamp'ом,
#         неалфавитных имён не бывает, сортировка по имени = по времени.
disable=SC2012
# SC2181: проверка "if [ $? -eq 0 ]" после команды — намеренный стиль
#         (odhcpd enabled/disabled), читаемее прямой подстановки здесь.
disable=SC2181
# SC2015: "A && B || C" используется как охранник для терминала (isatty),
#         где ветка C безвредна — это не имитация if-then-else.
disable=SC2015
# SC3045: printf "--- ... ---\n" — на busybox ash printf корректно печатает
#         строку, начинающуюся с "--"; для нашей платформы это не проблема.
disable=SC3045
# SC2115: rm -rf "$BACKUP_ROOT/$b" — $BACKUP_ROOT это фиксированная непустая
#         константа (/root/ipv6-off/backups), $b берётся из контролируемого
#         списка существующих бэкапов; до "/" раскрыться не может.
disable=SC2115
